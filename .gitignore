pulumi/**/Pulumi.*.yaml
pulumi/**/Pulumi.dev.yaml
pulumi/**/Pulumi.prod.yaml

# Python cache
pulumi/**/*.pyc
pulumi/**/__pycache__/
pulumi/**/*.pyo
pulumi/**/*.pyd

# Pulumi plugins
pulumi/**/.pulumi/

