# ============================================
# Terraform - Lab 04
# ============================================

# Terraform state files (содержат секреты!)
terraform/**/*.tfstate
terraform/**/*.tfstate.*
terraform/**/*.tfstate.backup
terraform/**/.terraform.tfstate.lock.info

# Terraform directory and lock file
terraform/**/.terraform/
terraform/**/.terraform.lock.hcl

# Variable files with sensitive data (Cloud ID, Folder ID, etc.)
terraform/**/terraform.tfvars
terraform/**/*.tfvars
terraform/**/*.auto.tfvars

# Credentials and service account keys
terraform/**/*.json
terraform/**/authorized_key.json
terraform/**/key.json
terraform/**/service-account-key.json

# Terraform crash logs
terraform/**/crash.log
terraform/**/crash.*.log

# Override files
terraform/**/override.tf
terraform/**/override.tf.json
terraform/**/*_override.tf
terraform/**/*_override.tf.json

# CLI configuration files
terraform/**/.terraformrc
terraform/**/terraform.rc

